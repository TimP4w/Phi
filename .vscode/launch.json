{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend - Local - DEV",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/backend/cmd/phi/__debug_bin",
      "preLaunchTask": "Build Backend",
      "env": {
        "PHI_DEV": "true",
        "PHI_KUBE_CONFIG_PATH": "/home/timp4w/.kube/config",
        "PHI_PROMETHEUS_URL": "http://localhost:9090",
        "PHI_ALLOWED_ORIGIN": "*",
        "PHI_LOG_LEVEL": "debug"
      }
    },
    {
      "name": "Frontend - Debugger",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/web",
      "runtimeExecutable": "/home/timp4w/.nix-profile/bin/brave"
    },
    {
      "name": "Frontend - Local - DEV",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "/home/timp4w/.nix-profile/bin/yarn",
      "cwd": "${workspaceFolder}/web",
      "runtimeArgs": ["dev"],
      "env": {
        "VITE_VERSION": "local",
        "VITE_URL": "http://localhost:8080",
        "VITE_WS": "http://localhost:8080/ws"
      }
    }
  ],
  "compounds": [
    {
      "name": "Local Dev Suite",
      "configurations": [
        "Frontend - Local - DEV",
        "Frontend - Debugger",
        "Backend - Local - DEV"
      ]
    }
  ]
}
